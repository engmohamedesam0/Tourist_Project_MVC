@model Tourist_Project_MVC.Models.Tourist

@{
    ViewData["Title"] = "Tourist Details";
}

<div class="container mt-4">
    <h2>👤 @Model.Name</h2>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Nationality</dt>
        <dd class="col-sm-9">@Model.Nationality</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">ID Number</dt>
        <dd class="col-sm-9">@Model.IdNumber</dd>

        <dt class="col-sm-3">Passport</dt>
        <dd class="col-sm-9">@Model.Passport</dd>

        <dt class="col-sm-3">Point Balance</dt>
        <dd class="col-sm-9">@Model.point_Balance pts</dd>

        <dt class="col-sm-3">Register Date</dt>
        <dd class="col-sm-9">@Model.RegisterDate.ToShortDateString()</dd>
    </dl>

    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>