@model Tourist_Project_MVC.Models.Tourist

@{
    ViewData["Title"] = "Edit Tourist";
}

<div class="container mt-4">
    <h2>✏️ Edit Tourist</h2>
    <hr />
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RegisterDate" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Nationality" class="form-label"></label>
            <input asp-for="Nationality" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" type="email" />
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" type="password" />
        </div>

        <div class="mb-3">
            <label asp-for="IdNumber" class="form-label">ID Number</label>
            <input asp-for="IdNumber" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Passport" class="form-label"></label>
            <input asp-for="Passport" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="point_Balance" class="form-label">Point Balance</label>
            <input asp-for="point_Balance" class="form-control" type="number" />
        </div>

        <button type="submit" class="btn btn-warning">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>