@{
    ViewData["Title"] = "Home";
    ViewData["IsHomePage"] = true;
}

<!-- Masthead / Hero -->
<header class="masthead">
    <div class="container px-4 px-lg-5 d-flex h-100 align-items-center justify-content-center">
        <div class="d-flex justify-content-center">
            <div class="text-center">
                <h1 class="mx-auto my-0 text-uppercase">EGYXPLORE</h1>
                <h2 class="text-white-50 mx-auto mt-2 mb-5">
                    Unlock Hidden Wonders Across Egypt
                </h2>
                <a class="btn btn-primary" asp-controller="Destination" asp-action="Index">
                    Explore Now
                </a>
            </div>
        </div>
    </div>
</header>

<!-- About Section -->
<section class="about-section text-center" id="about">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-lg-8">
                <h2 class="text-white mb-4">AI-Powered Smart Tourism Platform</h2>
                <p class="text-white-50">
                    EGYXPLORE combines Artificial Intelligence, GIS, and Gamification
                    to revolutionize tourism in Egypt. Discover hidden archaeological sites,
                    earn rewards, and experience Egypt like never before.
                </p>
            </div>
        </div>
        <img class="img-fluid" src="~/assets/img/ipad.png" alt="EGYXPLORE App" />
    </div>
</section>

<!-- Features Section -->
<section class="projects-section bg-light" id="projects">
    <div class="container px-4 px-lg-5">

        <!-- Feature 1 -->
        <div class="row gx-0 mb-4 mb-lg-5 align-items-center">
            <div class="col-xl-8 col-lg-7">
                <img class="img-fluid mb-3 mb-lg-0" src="~/assets/img/bg-masthead.jpg" alt="Hidden Destinations" />
            </div>
            <div class="col-xl-4 col-lg-5">
                <div class="featured-text text-center text-lg-left">
                    <h4>Hidden Destinations</h4>
                    <p class="text-black-50 mb-0">
                        Go beyond the pyramids. EGYXPLORE reveals Egypt's hidden
                        archaeological treasures — Dahshur, Dendera, Tanis, Siwa,
                        and Wadi El Hitan await your discovery.
                    </p>
                </div>
            </div>
        </div>

        <!-- Feature 2 -->
        <div class="row gx-0 mb-5 mb-lg-0 justify-content-center">
            <div class="col-lg-6">
                <img class="img-fluid" src="~/assets/img/demo-image-01.jpg" alt="AI Trip Planner" />
            </div>
            <div class="col-lg-6">
                <div class="bg-black text-center h-100 project">
                    <div class="d-flex h-100">
                        <div class="project-text w-100 my-auto text-center text-lg-left">
                            <h4 class="text-white">
                                <i class="fas fa-robot me-2"></i> AI Trip Planner
                            </h4>
                            <p class="mb-0 text-white-50">
                                Our AI generates personalized itineraries based on your
                                interests, budget, and trip duration. Smart GIS routing
                                finds the optimal path between destinations.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feature 3 -->
        <div class="row gx-0 justify-content-center">
            <div class="col-lg-6">
                <img class="img-fluid" src="~/assets/img/demo-image-02.jpg" alt="Gamification" />
            </div>
            <div class="col-lg-6 order-lg-first">
                <div class="bg-black text-center h-100 project">
                    <div class="d-flex h-100">
                        <div class="project-text w-100 my-auto text-center text-lg-right">
                            <h4 class="text-white">
                                <i class="fas fa-trophy me-2"></i> Gamification & Rewards
                            </h4>
                            <p class="mb-0 text-white-50">
                                Complete missions, earn points, and collect badges on
                                your Digital Heritage Passport. Redeem points for hotel
                                discounts, museum tickets, and exclusive experiences.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- Stats Section -->
<section class="signup-section" id="signup">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-8 mx-auto text-center">
                <i class="fas fa-map-marked-alt fa-2x mb-2 text-white"></i>
                <h2 class="text-white mb-5">Start Your Egyptian Adventure Today</h2>
                <div class="row text-white text-center">
                    <div class="col-md-4 mb-3">
                        <h3 class="fw-bold" style="color: #C8832A;">7000+</h3>
                        <p class="text-white-50">Archaeological Sites</p>
                    </div>
                    <div class="col-md-4 mb-3">
                        <h3 class="fw-bold" style="color: #C8832A;">27</h3>
                        <p class="text-white-50">Governorates</p>
                    </div>
                    <div class="col-md-4 mb-3">
                        <h3 class="fw-bold" style="color: #C8832A;">∞</h3>
                        <p class="text-white-50">Hidden Wonders</p>
                    </div>
                </div>
                <a class="btn btn-primary mt-3" asp-controller="Destination" asp-action="Index">
                    <i class="bi bi-geo-alt-fill me-2"></i> Browse Destinations
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Contact Cards -->
<section class="contact-section bg-black">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5">

            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-map-marked-alt text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">GIS Powered</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">
                            Smart route optimization using ArcGIS Network Analysis
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-robot text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">AI Driven</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">
                            Personalized recommendations powered by OpenAI
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-trophy text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">Gamified</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">
                            Missions, badges, and rewards for every explorer
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="social d-flex justify-content-center mt-4">
            <a class="mx-2" href="#"><i class="fab fa-twitter"></i></a>
            <a class="mx-2" href="#"><i class="fab fa-facebook-f"></i></a>
            <a class="mx-2" href="#"><i class="fab fa-github"></i></a>
        </div>
    </div>
</section>