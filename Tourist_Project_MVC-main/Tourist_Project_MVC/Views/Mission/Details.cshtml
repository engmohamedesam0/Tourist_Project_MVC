@model Tourist_Project_MVC.Models.Mission

@{
    ViewData["Title"] = "Mission Details";
}

<div class="container mt-4">
    <h2>🎯 @Model.Title</h2>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Type</dt>
        <dd class="col-sm-9">@Model.MissionType</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Points</dt>
        <dd class="col-sm-9">@Model.PointsReward</dd>

        <dt class="col-sm-3">Destination</dt>
        <dd class="col-sm-9">@Model.Destination.Name</dd>
    </dl>
    <hr />
    <h4>📊 Mission Engagement</h4>
    <dl class="row">
        <dt class="col-sm-3">Currently Attempting</dt>
        <dd class="col-sm-9">
            @(Model.UserMissions?.Count(um => um.Status == "In Progress") ?? 0)
        </dd>

        <dt class="col-sm-3">Tourists Completed</dt>
        <dd class="col-sm-9 text-success fw-bold">
            @(Model.UserMissions?.Count(um => um.Status == "Completed") ?? 0)
        </dd>
    </dl>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
