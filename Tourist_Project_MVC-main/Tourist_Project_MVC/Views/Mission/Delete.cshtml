@model Tourist_Project_MVC.Models.Mission

@{
    ViewData["Title"] = "Delete";
}
@if (User.Identity.IsAuthenticated)
{
    <div class="container mt-4">
        <h2 class="text-danger">🗑️ Delete Trip Plan</h2>
        <hr />
        <p class="lead">Are you sure you want to delete <strong>@Model.Title</strong>?</p>

        <dl class="row">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@Model.MissionType</dd>


            <dt class="col-sm-3">Points</dt>
            <dd class="col-sm-9">@Model.PointsReward</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>

}
