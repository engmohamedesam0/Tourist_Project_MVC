@model Tourist_Project_MVC.Models.TripPlan

@{
    ViewData["Title"] = "Trip Plan Details";
}

<div class="container mt-4">
    <h2>✈️ @Model.Title</h2>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Start Date</dt>
        <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

        <dt class="col-sm-3">End Date</dt>
        <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

        <dt class="col-sm-3">Duration</dt>
        <dd class="col-sm-9">@((Model.EndDate - Model.StartDate).Days) days</dd>

        <dt class="col-sm-3">Tourist ID</dt>
        <dd class="col-sm-9">@Model.TouristId</dd>
    </dl>

    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>